# ── LLM Provider ───────────────────────────────────────────────
# Choose one. Get a free Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GROQ_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# ── Settings ────────────────────────────────────────────────────
# Provider: gemini | groq | openai | anthropic | stub
RECALL_LLM_PROVIDER=gemini

# Model override (leave blank for provider default)
# Gemini:    gemini-2.0-flash | gemini-1.5-pro
# Groq:      llama3-8b-8192 | mixtral-8x7b-32768
# OpenAI:    gpt-4o-mini | gpt-4o
# Anthropic: claude-haiku-4-5-20251001
RECALL_MODEL=

# ── Embedder ────────────────────────────────────────────────────
# hash                  — Built-in, no install needed (default)
# sentence-transformers — Semantic search (pip install sentence-transformers)
RECALL_EMBEDDER=sentence-transformers

# Sentence-transformers model (only if RECALL_EMBEDDER=sentence-transformers)
# all-MiniLM-L6-v2    — 80MB,  fastest, good quality  (default)
# all-MiniLM-L12-v2   — 120MB, balanced
# all-mpnet-base-v2   — 420MB, best quality, slower
RECALL_ST_MODEL=